{
  "name": "safar",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=@safar/frontend",
    "dev:backend": "npm run start:dev --workspace=@safar/backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:shared": "npm run build --workspace=@safar/shared",
    "build:frontend": "npm run build --workspace=@safar/frontend",
    "build:backend": "npm run build --workspace=@safar/backend",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run check --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.5.0"
  }
}
